# ============================================================
# EXAMINER - Production Environment
# Copy this to .env on your server and fill in the values
# ============================================================

# --- Database ---
POSTGRES_DB=examiner
POSTGRES_USER=examiner
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- JWT (REQUIRED - generate with: openssl rand -hex 32) ---
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# --- AI Providers (at least one needed for question gen / grading) ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Object Storage ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Frontend API URL ---
# Set this to your server's IP or domain.
# The frontend calls this from the BROWSER, so it must be reachable externally.
# Examples:
#   http://123.45.67.89/api/v1
#   http://myserver.example.com/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# --- CORS ---
# Must match how users access your site in the browser
# Comma-separated list of origins (no brackets or quotes needed)
# Examples:
#   http://123.45.67.89
#   http://myserver.example.com
CORS_ORIGINS=http://YOUR_SERVER_IP

# --- Port (default 80) ---
PORT=80

# --- Feature Flags ---
FEATURE_PROCTORING_ENABLED=false
FEATURE_TAB_SWITCH_DETECTION=true
FEATURE_COPY_PASTE_BLOCK=false
FEATURE_FULLSCREEN_REQUIRED=false
FEATURE_ADAPTIVE_ENABLED=true
