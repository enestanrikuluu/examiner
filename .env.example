# Database
DATABASE_URL=postgresql+asyncpg://examiner:examiner@localhost:5432/examiner

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=examiner
MINIO_USE_SSL=false

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# AI Providers
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Application
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# Feature Flags
FEATURE_PROCTORING_ENABLED=false
FEATURE_TAB_SWITCH_DETECTION=true
FEATURE_COPY_PASTE_BLOCK=false
FEATURE_FULLSCREEN_REQUIRED=false
FEATURE_ADAPTIVE_ENABLED=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
